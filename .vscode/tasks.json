{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "启动本地预览服务器 (端口 4173)",
      "type": "shell",
      "command": "python -m http.server 4173 --bind 127.0.0.1",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {}
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": { "regexp": "^Serving HTTP on .* (port \\d+)" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Serving HTTP on"
        }
      },
      "presentation": { "reveal": "always", "echo": true }
    },
    {
      "label": "在 Cursor 内置浏览器中打开 stars_ai_preview",
      "dependsOn": "启动本地预览服务器 (端口 4173)",
      "type": "shell",
      "command": "echo 服务器已启动。请按 Ctrl+Shift+P -> Simple Browser: Show -> 粘贴: http://127.0.0.1:4173/stars_ai_preview.html （若仍 -324 请用系统浏览器打开该地址）",
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "在系统浏览器中打开 stars_ai_preview（若 Simple Browser 报 -324 用此方式）",
      "type": "shell",
      "command": "Start-Process \"http://127.0.0.1:4173/stars_ai_preview.html\"",
      "problemMatcher": [],
      "presentation": { "reveal": "silent" }
    }
  ]
}
